rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ARC PERP TESTNET — open read for wallet-based auth
    // Write is restricted to server (Admin SDK bypasses rules)
    
    match /users/{userId} {
      // Anyone can read their own user doc (wallet address as userId)
      allow read: if true;
      // Allow user creation from client (new wallet signup)
      allow create: if true;
      // Balance updates only via server Admin SDK
      allow update: if request.resource.data.diff(resource.data)
                       .affectedKeys().hasOnly(['displayName', 'lastLogin', 'lastActivity']);

      match /positions/{positionId} {
        allow read: if true;
        allow write: if false; // server only
      }

      match /orders/{orderId} {
        allow read: if true;
        allow write: if false; // server only
      }
    }
  }
}
